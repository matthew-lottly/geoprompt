# Auto-detect text files and normalise line endings
* text=auto

# Force LF for source code
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.rst text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.gz binary
*.tar binary
*.whl binary
